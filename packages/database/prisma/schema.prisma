generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Better Auth core tables (managed by Better Auth adapter)
// ============================================================

model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  sessions    Session[]
  accounts    Account[]
  members     Member[]
  invitations Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime @map("expires_at")
  token                String
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  ipAddress            String?  @map("ip_address")
  userAgent            String?  @map("user_agent")
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?  @map("active_organization_id")

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

// ============================================================
// Better Auth organization plugin tables
// Organization = Clinic (tenant). organization.id IS the tenantId.
// ============================================================

model Organization {
  id        String   @id
  name      String
  slug      String
  logo      String?
  createdAt DateTime @map("created_at")
  metadata  String?

  members     Member[]
  invitations Invitation[]

  // Business extension: clinic-specific settings
  clinicSettings ClinicSettings?

  // Tenant-scoped business data
  consentRecords  ConsentRecord[]
  erasureRequests ErasureRequest[]

  // WhatsApp & Agent
  whatsappInstance WhatsappInstance?
  agentConfig      AgentConfig?
  conversations    Conversation[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime     @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime     @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  inviterId      String       @map("inviter_id")
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ============================================================
// CliniqAI business models
// ============================================================

/// Clinic-specific settings that extend the Better Auth Organization.
/// Organization.id is used as the tenantId for all RLS policies.
model ClinicSettings {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @unique @map("organization_id")
  timezone       String   @default("America/Sao_Paulo")
  retentionDays  Int      @default(365) @map("retention_days")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("clinic_settings")
}

model ConsentRecord {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id")
  leadPhone       String   @map("lead_phone")
  consentGiven    Boolean  @map("consent_given")
  consentVersion  String   @map("consent_version")
  consentChannel  String   @map("consent_channel")
  consentMessage  String   @map("consent_message")
  ipAddress       String?  @map("ip_address")
  createdAt       DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("consent_records")
}

model ErasureRequest {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id")
  leadPhone      String    @map("lead_phone")
  requestedAt    DateTime  @default(now()) @map("requested_at")
  processedAt    DateTime? @map("processed_at")
  status         String    @default("pending")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("erasure_requests")
}

// ============================================================
// WhatsApp & AI Agent models (Phase 2)
// ============================================================

/// WhatsApp instance connected to a clinic via Evolution API.
/// One instance per organization (clinic).
model WhatsappInstance {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @unique @map("organization_id")
  instanceName   String    @unique @map("instance_name")
  status         String    @default("disconnected") // open | close | connecting | disconnected
  phoneNumber    String?   @map("phone_number")
  qrCodeBase64   String?   @map("qr_code_base64")
  connectedAt    DateTime? @map("connected_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("whatsapp_instances")
}

/// Per-clinic AI agent configuration (persona, tone, operating hours).
model AgentConfig {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @unique @map("organization_id")
  personaName         String   @default("Sofia") @map("persona_name")
  tone                String   @default("informal")
  specialtyText       String?  @map("specialty_text")
  emojiUsage          Boolean  @default(true) @map("emoji_usage")
  operatingHoursStart Int      @default(8) @map("operating_hours_start")
  operatingHoursEnd   Int      @default(20) @map("operating_hours_end")
  timezone            String   @default("America/Sao_Paulo")
  maxTurns            Int      @default(20) @map("max_turns")
  systemPromptExtra   String?  @map("system_prompt_extra")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

/// Active conversation thread between a lead and the AI agent.
model Conversation {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id")
  remoteJid          String   @map("remote_jid")
  threadId           String   @unique @map("thread_id") // format: {orgId}:{remoteJid}
  status             String   @default("active") // active | human_handling | closed
  turnCount          Int      @default(0) @map("turn_count")
  qualificationStage String   @default("consent") @map("qualification_stage")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, remoteJid])
  @@index([organizationId, status])
  @@map("conversations")
}
